# STT 测试平台环境配置示例
# 复制此文件为 .env 并根据环境修改

# ── 应用配置 ──────────────────────────────────────
APP_NAME=STT Test Platform
APP_VERSION=0.1.0

# ── 环境配置 ──────────────────────────────────────
# test: 测试环境（启用对话追踪）
# production: 生产环境（禁用对话追踪，保护用户隐私）
ENVIRONMENT=test
# MQTT broker profile for local testing.
# local: use WSL NanoMQ (replaces previous Mosquitto).
# relay/custom: allow overriding broker host/port/TLS when needed.
MQTT_BROKER_PROFILE=local
MQTT_ENV=development
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS=false
# MQTT TLS 证书配置（仅 MQTT_TLS=true 时需要）
# 与 chatbot 侧 MQTT_TLS_CA_CERT / CLIENT_CERT / CLIENT_KEY 环境变量对齐
# MQTT_TLS_CA_CERT=
# MQTT_TLS_CLIENT_CERT=
# MQTT_TLS_CLIENT_KEY=
# MQTT_TLS_INSECURE=false

# UAT relay broker（设备统一接入 gateway）
# MQTT_BROKER_PROFILE=relay 时读取以下配置
# MQTT_RELAY_HOST=server.zebbingo.com
# MQTT_RELAY_PORT=1883
# MQTT_RELAY_TLS=false
# MQTT_RELAY_ENV=uat

# ── 对话追踪配置 ───────────────────────────────────
# true: 启用对话追踪功能（记录 TTS 音频与对话的关联）
# false: 禁用对话追踪功能（不记录关联信息）
ENABLE_CONVERSATION_TRACKING=true

# ── MySQL 配置 ─────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Zebbingo2024
MYSQL_DATABASE=ZebbieDb

# ── MiniMax TTS API 配置 ───────────────────────────
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# ── 其他配置 ───────────────────────────────────────
# ... 其他配置项 ...
