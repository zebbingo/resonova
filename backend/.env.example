# STT 娴嬭瘯骞冲彴鐜閰嶇疆绀轰緥
# 澶嶅埗姝ゆ枃浠朵负 .env 骞舵牴鎹幆澧冧慨鏀?

# 鈹€鈹€ 搴旂敤閰嶇疆 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
APP_NAME=STT Test Platform
APP_VERSION=0.1.0

# 鈹€鈹€ 鐜閰嶇疆 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
# test: 娴嬭瘯鐜锛堝惎鐢ㄥ璇濊拷韪級
# production: 生产环境（禁用对话追踪，保护用户隐私）
ENVIRONMENT=test
# MQTT broker profile for local testing.
# local: use the workspace Mosquitto / local relay by default.
# relay/custom: allow overriding broker host/port/TLS when needed.
MQTT_BROKER_PROFILE=local
MQTT_ENV=development
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS=false

# 鈹€鈹€ 瀵硅瘽杩借釜閰嶇疆 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
# true: 鍚敤瀵硅瘽杩借釜鍔熻兘锛堣褰?TTS 闊抽涓庡璇濈殑鍏宠仈锛?
# false: 绂佺敤瀵硅瘽杩借釜鍔熻兘锛堜笉璁板綍鍏宠仈淇℃伅锛?
ENABLE_CONVERSATION_TRACKING=true

